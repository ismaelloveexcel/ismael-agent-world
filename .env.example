# ─────────────────────────────────────────────
# Ismael Agent World — Environment Variables
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────

# ── Next.js public config ──────────────────
# Base URL of this Next.js app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Supabase ───────────────────────────────
# Project URL from Supabase dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon/public key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service-role key — SERVER SIDE ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Python FastAPI execution engine ────────
# Railway deployment URL (no trailing slash)
FASTAPI_BASE_URL=http://localhost:8000

# Shared secret — Next.js → FastAPI auth header
FASTAPI_SECRET=change-me-to-a-long-random-string

# ── OpenAI ─────────────────────────────────
# Used by FastAPI for LLM calls + embeddings (text-embedding-3-small)
OPENAI_API_KEY=sk-your-openai-api-key

# Model used for agent reasoning (e.g. gpt-4o, gpt-4-turbo)
OPENAI_MODEL=gpt-4o

# ── Serper (web search tool) ───────────────
# API key from serper.dev
SERPER_API_KEY=your-serper-api-key

# ── Lemon Squeezy (payments — Phase 3+) ───
LEMON_SQUEEZY_API_KEY=your-lemon-squeezy-api-key
LEMON_SQUEEZY_WEBHOOK_SECRET=your-webhook-secret

# ── Feature flags ──────────────────────────
# Set to 'true' to bypass auth in local dev (Phase 1 only)
NEXT_PUBLIC_MOCK_AUTH=true

# Set to 'true' to use seed/mock data instead of live Supabase
NEXT_PUBLIC_USE_MOCK_DATA=true
